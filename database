
CREATE TABLE customers (

    phone INT PRIMARY KEY,
    name VARCHAR(55),
    email VARCHAR(55),
    age INT

)

CREATE TABLE screenings(

    screening_id INT PRIMARY KEY,
    cinema_hall_id INT,
    time DATETIME,
    movie_id INT,
    FOREIGN KEY (cinema_hall_id) REFERENCES cinema_halls(cinema_hall_id),
    FOREIGN KEY (movie_id) REFERENCES movies(movie_id)

)

CREATE TABLE movies(

    movie_id INT PRIMARY KEY,
    name VARCHAR(55),
    description VARCHAR(155),
    age_limit INT,
    genre INT,
    length INT,
    FOREIGN KEY (genre) REFERENCES genres(id)

)

CREATE TABLE actors(

    id INT PRIMARY KEY,
    name VARCHAR(55)

)

CREATE TABLE actors_in_movie(

    id INT PRIMARY KEY,
    movie_id INT,
    actor_id INT,
    FOREIGN KEY (movie_id) REFERENCES movies(movie_id),
    FOREIGN KEY (actor_id) REFERENCES actors(id)

)

CREATE TABLE genres(

    id INT PRIMARY KEY,
    name VARCHAR(55)

)

CREATE TABLE cinema_halls(

   cinema_hall_id INT PRIMARY KEY,
   rows INT,
   seats INT

)

CREATE TABLE seats(

    seat_id INT PRIMARY KEY,
    seat INT,
    row INT,
    cinema_hall_id INT,
    FOREIGN KEY (cinema_hall_id) REFERENCES cinema_halls(cinema_hall_id)

)

CREATE TABLE reservations(

    reservation_id INT PRIMARY KEY,
    customer INT,
    screening_id INT,
    seat_id INT,
    FOREIGN KEY (customer) REFERENCES customers(phone),
    FOREIGN KEY (screening_id) REFERENCES screenings(screening_id),
    FOREIGN KEY (seat_id) REFERENCES seats(seat_id),
    CONSTRAINT available UNIQUE(seat_id, screening_id)

)

